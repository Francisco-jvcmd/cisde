---
import LayoutCorporativo from '../layouts/LayoutCorporativo.astro';
---

<LayoutCorporativo title="Contacto" description="Inicie una conversación estratégica con CISDE Ecuador">
  
  <!-- ═══════════════════════════════════════════════════
       SPLIT-SCREEN LAYOUT
  ═══════════════════════════════════════════════════ -->
  <div class="flex flex-col lg:flex-row min-h-screen">
    
    <!-- LEFT PANEL — Dark Immersive -->
    <div class="lg:w-[45%] bg-brand-dark text-brand-light flex flex-col justify-between px-8 py-32 lg:px-16 lg:py-20 relative overflow-hidden lg:fixed lg:top-0 lg:left-0 lg:h-screen">
      <!-- Ambient light -->
      <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-brand-primary opacity-[0.04] rounded-full blur-[150px] pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-brand-primary opacity-[0.03] rounded-full blur-[100px] pointer-events-none"></div>
      
      <!-- Top -->
      <div class="relative z-10 flex-grow flex flex-col justify-center">
        <span class="text-[10px] tracking-[0.4em] uppercase font-bold text-brand-primary block mb-8 gsap-reveal">Contacto Corporativo</span>
        <h1 class="font-heading text-fluid-h2 mb-10 leading-[1.1] gsap-reveal">
          Inicie el <span class="italic text-brand-primary">Diálogo</span><br/>Estratégico
        </h1>
        <p class="text-brand-light/60 font-light leading-[1.8] max-w-md mb-16 text-lg gsap-reveal">
          Nuestro equipo de especialistas analizará sus requerimientos bajo la más estricta confidencialidad, ofreciendo una propuesta personalizada en un plazo no mayor a 48 horas hábiles.
        </p>
        
        <div class="space-y-10 gsap-reveal">
          <div class="flex items-start gap-6 group">
            <div class="w-10 h-10 border border-brand-primary/20 flex items-center justify-center flex-shrink-0 group-hover:border-brand-primary/60 transition-colors duration-500">
              <svg class="w-4 h-4 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
            </div>
            <div>
              <p class="text-[10px] uppercase tracking-[0.3em] font-bold text-brand-primary mb-2">Sede Corporativa</p>
              <p class="font-light text-brand-light/70 leading-relaxed text-sm">Av. República del Salvador y Moscú<br/>Edificio B2B, Piso 14 · Quito, Ecuador</p>
            </div>
          </div>

          <div class="flex items-start gap-6 group">
            <div class="w-10 h-10 border border-brand-primary/20 flex items-center justify-center flex-shrink-0 group-hover:border-brand-primary/60 transition-colors duration-500">
              <svg class="w-4 h-4 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
            </div>
            <div>
              <p class="text-[10px] uppercase tracking-[0.3em] font-bold text-brand-primary mb-2">Comunicaciones</p>
              <p class="font-light text-brand-light/70 leading-relaxed text-sm">contacto@cisde.ec<br/>+593 2 000 0000</p>
            </div>
          </div>

          <div class="flex items-start gap-6 group">
            <div class="w-10 h-10 border border-brand-primary/20 flex items-center justify-center flex-shrink-0 group-hover:border-brand-primary/60 transition-colors duration-500">
              <svg class="w-4 h-4 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <div>
              <p class="text-[10px] uppercase tracking-[0.3em] font-bold text-brand-primary mb-2">Horario de Atención</p>
              <p class="font-light text-brand-light/70 leading-relaxed text-sm">Lunes a Viernes<br/>08:00 — 18:00 (ECT)</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom -->
      <div class="relative z-10 mt-16 pt-8 border-t border-brand-light/5">
        <p class="text-[10px] tracking-[0.2em] uppercase text-brand-light/30 font-light">CISDE Ecuador · Información confidencial</p>
      </div>
    </div>

    <!-- RIGHT PANEL — Form -->
    <div class="lg:w-[55%] lg:ml-[45%] bg-brand-light flex flex-col justify-center px-8 py-32 lg:px-24 min-h-screen">
      <div class="max-w-lg w-full mx-auto">
        
        <div class="mb-16 gsap-reveal">
          <span class="text-[10px] tracking-[0.4em] uppercase font-bold text-brand-primary block mb-4">Formulario de Contacto</span>
          <p class="text-brand-dark/60 font-light text-sm">Todos los campos marcados son obligatorios. Su información será tratada conforme a la LOPDP.</p>
        </div>

        <form id="contact-form" class="space-y-12">
          <div id="form-feedback" class="hidden p-6 text-sm font-light border-l-2 shadow-sm mb-8"></div>

          <!-- Name -->
          <div class="relative gsap-reveal">
            <input type="text" id="name" name="name" required placeholder=" " autocomplete="name"
              class="block w-full bg-transparent border-b-2 border-brand-dark/10 py-4 px-0 text-brand-dark font-light focus:outline-none focus:border-brand-primary transition-colors duration-500 peer" />
            <label for="name" class="absolute left-0 top-4 text-[11px] uppercase tracking-[0.2em] font-semibold text-brand-dark/40 transition-all duration-300 pointer-events-none peer-focus:-top-4 peer-focus:text-[9px] peer-focus:text-brand-primary peer-[:not(:placeholder-shown)]:-top-4 peer-[:not(:placeholder-shown)]:text-[9px]">
              Nombre Completo *
            </label>
            <div class="absolute bottom-0 left-0 w-0 h-0.5 bg-brand-primary peer-focus:w-full transition-all duration-700 ease-corporate"></div>
          </div>

          <!-- Email -->
          <div class="relative gsap-reveal">
            <input type="email" id="email" name="email" required placeholder=" " autocomplete="email"
              class="block w-full bg-transparent border-b-2 border-brand-dark/10 py-4 px-0 text-brand-dark font-light focus:outline-none focus:border-brand-primary transition-colors duration-500 peer" />
            <label for="email" class="absolute left-0 top-4 text-[11px] uppercase tracking-[0.2em] font-semibold text-brand-dark/40 transition-all duration-300 pointer-events-none peer-focus:-top-4 peer-focus:text-[9px] peer-focus:text-brand-primary peer-[:not(:placeholder-shown)]:-top-4 peer-[:not(:placeholder-shown)]:text-[9px]">
              Correo Corporativo *
            </label>
            <div class="absolute bottom-0 left-0 w-0 h-0.5 bg-brand-primary peer-focus:w-full transition-all duration-700 ease-corporate"></div>
          </div>

          <!-- Company -->
          <div class="relative gsap-reveal">
            <input type="text" id="company" name="company" placeholder=" " autocomplete="organization"
              class="block w-full bg-transparent border-b-2 border-brand-dark/10 py-4 px-0 text-brand-dark font-light focus:outline-none focus:border-brand-primary transition-colors duration-500 peer" />
            <label for="company" class="absolute left-0 top-4 text-[11px] uppercase tracking-[0.2em] font-semibold text-brand-dark/40 transition-all duration-300 pointer-events-none peer-focus:-top-4 peer-focus:text-[9px] peer-focus:text-brand-primary peer-[:not(:placeholder-shown)]:-top-4 peer-[:not(:placeholder-shown)]:text-[9px]">
              Empresa u Organización
            </label>
            <div class="absolute bottom-0 left-0 w-0 h-0.5 bg-brand-primary peer-focus:w-full transition-all duration-700 ease-corporate"></div>
          </div>

          <!-- Subject -->
          <div class="relative gsap-reveal">
            <select id="subject" name="subject" required
              class="block w-full bg-transparent border-b-2 border-brand-dark/10 py-4 px-0 text-brand-dark font-light focus:outline-none focus:border-brand-primary transition-colors duration-500 appearance-none cursor-pointer">
              <option value="" disabled selected>Seleccionar área de interés *</option>
              <option value="consultoria">Consultoría Estratégica</option>
              <option value="lopdp">Cumplimiento LOPDP</option>
              <option value="digital">Innovación Digital B2B</option>
              <option value="general">Consulta General</option>
            </select>
            <svg class="absolute right-0 top-5 w-4 h-4 text-brand-dark/30 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
          </div>

          <!-- Message -->
          <div class="relative gsap-reveal">
            <textarea id="message" name="message" rows="4" required placeholder=" "
              class="block w-full bg-transparent border-b-2 border-brand-dark/10 py-4 px-0 text-brand-dark font-light focus:outline-none focus:border-brand-primary transition-colors duration-500 resize-none peer"></textarea>
            <label for="message" class="absolute left-0 top-4 text-[11px] uppercase tracking-[0.2em] font-semibold text-brand-dark/40 transition-all duration-300 pointer-events-none peer-focus:-top-4 peer-focus:text-[9px] peer-focus:text-brand-primary peer-[:not(:placeholder-shown)]:-top-4 peer-[:not(:placeholder-shown)]:text-[9px]">
              Descripción del Requerimiento *
            </label>
            <div class="absolute bottom-0 left-0 w-0 h-0.5 bg-brand-primary peer-focus:w-full transition-all duration-700 ease-corporate"></div>
          </div>

          <!-- LOPDP Consent -->
          <div class="flex items-start gap-4 pt-4 gsap-reveal">
            <div class="relative flex items-center justify-center mt-1 flex-shrink-0">
              <input type="checkbox" id="consent" name="consent" required
                class="w-5 h-5 appearance-none border-2 border-brand-dark/15 checked:bg-brand-primary checked:border-brand-primary transition-all duration-300 cursor-pointer peer" />
              <svg class="absolute w-3 h-3 text-white pointer-events-none opacity-0 peer-checked:opacity-100 transition-opacity duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <label for="consent" class="text-xs text-brand-dark/50 leading-relaxed font-light cursor-pointer">
              Consiento expresamente el tratamiento de mis datos personales conforme a la <strong class="text-brand-dark font-medium">Ley Orgánica de Protección de Datos Personales (Ecuador)</strong>, exclusivamente para el seguimiento y gestión de esta solicitud comercial. *
            </label>
          </div>

          <!-- Submit -->
          <div class="pt-8 gsap-reveal">
            <button type="submit" class="magnetic-btn bg-brand-primary text-white w-full md:w-auto">
              <span class="btn-label">Enviar Solicitud Formal</span>
              <span class="btn-arrow bg-white"></span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

</LayoutCorporativo>

<script>
  import { supabase } from '../lib/supabase';
  import type { Lead } from '../lib/supabase';

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const feedback = document.getElementById('form-feedback') as HTMLDivElement;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.style.opacity = '0.6';
      }

      const formData = new FormData(form);
      const sanitize = (str: string) => str.replace(/[<>]/g, '').trim();

      const leadData: Lead = {
        name: sanitize(formData.get('name') as string),
        email: sanitize(formData.get('email') as string),
        company: sanitize(formData.get('company') as string || ''),
        message: sanitize(formData.get('message') as string),
        consent: formData.get('consent') === 'on',
      };

      try {
        const { error } = await supabase
          .from('leads_cisde')
          .insert([leadData]);

        if (error) throw error;

        feedback.className = 'block p-6 text-sm font-light bg-brand-light border-l-2 border-brand-primary text-brand-dark shadow-sm mb-8';
        feedback.innerHTML = '<strong class="font-semibold block mb-1 tracking-wide text-[11px] uppercase">Solicitud Registrada</strong><span class="text-brand-dark/60">Nuestro equipo senior se comunicará con usted en un plazo máximo de 48 horas hábiles.</span>';
        form.reset();

      } catch (err) {
        console.error('Error submitting lead:', err);
        feedback.className = 'block p-6 text-sm font-light bg-red-50 border-l-2 border-red-400 text-red-900 shadow-sm mb-8';
        feedback.innerHTML = '<strong class="font-semibold block mb-1 tracking-wide text-[11px] uppercase">Error de Conexión</strong><span class="text-red-700/70">No fue posible procesar su solicitud. Por favor intente nuevamente.</span>';
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.style.opacity = '1';
        }
        setTimeout(() => { feedback.classList.add('hidden'); }, 8000);
      }
    });
  }
</script>
